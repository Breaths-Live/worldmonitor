# ============================================
# World Monitor — LOCAL DEVELOPMENT (.env.local)
# ============================================
# 
# Copy this file to .env.local and fill in the values you need.
# Start with TIER 1 keys for best experience.
# See API_COMPARISON_AND_SETUP.md for detailed setup guide.
#
# NEVER COMMIT THIS FILE — add to .gitignore
#
# ============================================

# ========== TIER 1: CORE AI & MARKET DATA ==========
# Start here for real-time intelligence

# ===== AI Summarization (Recommended: Groq) =====
# Free: 14,400 requests/day | Get: https://console.groq.com/
# Without this: Summaries fall back to browser-side WASM (slow)
GROQ_API_KEY=

# Alternative: OpenRouter (Free: 50 req/day)
# Get: https://openrouter.ai/
OPENROUTER_API_KEY=

# ===== Market Data =====
# Finnhub: Real-time stock/crypto quotes
# Free: 60 calls/min | Get: https://finnhub.io/
FINNHUB_API_KEY=

# ========== TIER 2: ECONOMIC INTELLIGENCE ==========

# FRED (Federal Reserve Economic Data)
# Free: Unlimited | Get: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# EIA (U.S. Energy Information Administration)
# Free: Unlimited | Get: https://www.eia.gov/opendata/
EIA_API_KEY=

# ========== TIER 3: THREAT INTELLIGENCE & CONFLICTS ==========

# ACLED (Armed Conflict Location & Event Data)
# Free tier: Limited | Get: https://acleddata.com/
# Without: Map shows only cached conflict data
ACLED_ACCESS_TOKEN=

# OTX (AlienVault Threat Intelligence)
# Free: Unlimited basic | Get: https://otx.alienvault.com/
OTX_API_KEY=

# AbuseIPDB (IP Reputation)
# Free: 1,500 checks/day | Get: https://www.abuseipdb.com/
ABUSEIPDB_API_KEY=

# AbuseChURL Threat List (Malicious URLs)
# Free: Limited | Get: https://urlhaus.abuse.ch/
URLHAUS_AUTH_KEY=

# ========== TIER 3: ADVANCED AVIATION & MILITARY ==========

# Wingbits (Military Aircraft Enrichment)
# Requires API key tier | Get: https://www.wingbits.com/
WINGBITS_API_KEY=

# ICAO NOTAM (Airspace Restrictions)
# Commercial only | Get: Contact ICAO
ICAO_API_KEY=

# AviationStack (Flight Tracking)
# Free: 100 calls/month | Get: https://aviationstack.com/
AVIATIONSTACK_API=

# ========== TIER 4: LOCAL AI (OPTIONAL) ==========
# Use this for free offline summaries (requires Docker/binary)

# Ollama Local LLM
# Download: https://ollama.ai/ 
# Then: ollama pull mistral (or llama2, neural-chat)
OLLAMA_API_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# ========== TIER 5: CACHE & PERSISTENCE ==========
# Optional but recommended for production

# Upstash Redis (Cross-user caching, risk score dedup)
# Free: 10,000 commands/day | Get: https://upstash.com/
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ========== TIER 6: WEBSOCKET RELAY (PRODUCTION ONLY) ==========
# For real-time AIS/OpenSky tracking — requires infrastructure setup
# See docs/RELAY_PARAMETERS.md for detailed setup

# AIS Relay (Vessel Tracking)
# Requires: Custom WebSocket relay service + AIS data stream api key
WS_RELAY_URL=
AISSTREAM_API_KEY=

# OpenSky Relay (Military Flight Tracking) 
# Requires: Custom WebSocket relay service + OpenSky credentials
VITE_OPENSKY_RELAY_URL=
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# ========== TIER 7: AFFILIATE & MONETIZATION (OPTIONAL) ==========
# Enable earning via travel & service partner commissions.
# See: src/features/affiliate/config/affiliate-ids.md for setup.

# Travel & Booking Partners
REACT_APP_TRAVELPAYOUTS_ID=
REACT_APP_GETYOURGUIDE_ID=
REACT_APP_BOOKING_ID=
REACT_APP_EXPEDIA_ID=

# Travel Services
REACT_APP_AIRALO_ID=
REACT_APP_DISCOVERCARS_ID=
REACT_APP_SAFETYWING_ID=

# Google Sheets Affiliate Sync (Lucky App)
# 1. Go to Google Sheet > File > Share > Publish to web
# 2. Select "Whole Document" and "Comma-separated values (.csv)"
# 3. Paste the URL here
VITE_AFFILIATE_SHEET_CSV_URL=

# ========== TIER 8: ENTERPRISE INTEGRATIONS ==========

# Cloudflare API (DNS, WAF management)
CLOUDFLARE_API_TOKEN=

# WTO (World Trade Organization) Trade Data
WTO_API_KEY=

# World Monitor API (Internal — usually not needed locally)
WORLDMONITOR_API_KEY=

# ============================================
# QUICK START CHECKLIST
# ============================================
# 
# 1. Free tier setup (5 minutes):
#    - Add GROQ_API_KEY (https://console.groq.com/)
#    - Add FINNHUB_API_KEY (https://finnhub.io/)
#
# 2. Enhanced intel (10 minutes):
#    - Add FRED_API_KEY (https://fred.stlouisfed.org/)
#    - Add EIA_API_KEY (https://www.eia.gov/opendata/)
#    - Add ACLED_ACCESS_TOKEN (https://acleddata.com/)
#
# 3. Offline AI (optional):
#    - Install Ollama (https://ollama.ai/)
#    - Add OLLAMA_API_URL + OLLAMA_MODEL
#
# 4. Start dev server:
#    npm run dev
#
# 5. Verify setup:
#    Settings → Diagnostics → Check "Feature Availability"
#
# ============================================

